PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=admin
DB_DATABASE=schoolpro

JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:4200
# Public API base URL (used to build Twilio statusCallback webhook URL)
API_PUBLIC_URL=http://localhost:3001
# Optional explicit override for Twilio delivery status callbacks:
# TWILIO_STATUS_CALLBACK_URL=https://your-domain.com/webhooks/whatsapp-status

# BullMQ job queue (WhatsApp result notifications)
REDIS_URL=redis://127.0.0.1:6379
# Set to false to skip BullMQ workers when Redis is not installed (dev without Redis)
REDIS_ENABLED=true

WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# E.164 SMS sender used for result notification fallback (TWILIO_SMS_FROM)
TWILIO_SMS_FROM=

# WhatsApp results notification module (services/whatsapp.js)
TWILIO_WHATSAPP_NUMBER=
# Set to true once you have an approved Twilio Content Template (production).
WHATSAPP_USE_TEMPLATE=false
TWILIO_CONTENT_SID=

# --- Demo account system -----------------------------------------------------
# Master switch. When false, /api/auth/demo-login 404s and no demo DB/cron starts.
DEMO_FEATURE_ENABLED=true

# Separate Postgres database for demo data (same server as DB_HOST by default).
# Isolation is enforced by an AsyncLocalStorage-routed DataSource proxy, so demo
# requests can never read/write the production database defined above.
DEMO_DB_HOST=localhost
DEMO_DB_PORT=5432
DEMO_DB_USERNAME=postgres
DEMO_DB_PASSWORD=admin
DEMO_DB_DATABASE=school_pro_demo

# Demo JWTs always expire after this many minutes, regardless of the school's
# configured session timeout policy.
DEMO_JWT_TTL_MINUTES=45

# node-cron expression for the recurring demo data reset (default: daily at midnight).
DEMO_RESET_CRON=0 0 */1 * *
# Force a full reseed on every server boot (handy in local dev).
DEMO_RESET_ON_BOOT=false
# Requests per minute allowed per demo session on write (non-GET) endpoints.
DEMO_WRITE_RATE_LIMIT_PER_MINUTE=20

# --- File storage (LMS, library, submissions) --------------------------------
# local = disk under ./uploads (default for dev)
# s3    = AWS S3 or S3-compatible (R2, MinIO) for production
STORAGE_DRIVER=local
UPLOAD_MAX_MB=25
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional custom endpoint for R2/MinIO:
S3_ENDPOINT=
# Public base URL for object links (CDN or bucket URL):
S3_PUBLIC_BASE_URL=