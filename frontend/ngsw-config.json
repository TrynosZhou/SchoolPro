{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/i18n/**",
          "/assets/**",
          "/*.(svg|png|jpg|jpeg|gif|webp|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-readonly-cache",
      "urls": [
        "**/api/attendance/**",
        "**/api/exams/terms",
        "**/api/exams/types",
        "**/api/exams/report-cards/**",
        "**/api/exams/grade-boundaries",
        "**/api/timetable/**",
        "**/api/dashboard/school-links"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 120,
        "maxAge": "7d",
        "timeout": "8s"
      }
    }
  ],
  "navigationUrls": [
    "/**",
    "!/**/*.*",
    "!/**/*__*",
    "!/**/*__*/**"
  ]
}
